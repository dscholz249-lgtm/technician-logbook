# Supabase — create a project at supabase.com and copy these from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Canonical origin of this Next.js app — used to build the magic-link callback URL.
# Local dev: http://localhost:3000
# Production: https://your-railway-domain.up.railway.app (or custom domain)
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000

# Base URL of the Express SMS server (no trailing slash).
# Local: http://localhost:4000 (or whatever port the Express app binds to)
# Production: the Railway public URL of the Express service
EXPRESS_API_URL=http://localhost:4000
